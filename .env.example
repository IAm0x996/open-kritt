# PostgreSQL
POSTGRES_USER=open_kritt
POSTGRES_PASSWORD=open_kritt_password
POSTGRES_DB=open_kritt
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432

# Host path where PostgreSQL data is persisted.
POSTGRES_DATA_DIR=./.data/postgres

# Shared database connection used by the backend and engine containers
DATABASE_URL=postgresql://open_kritt:open_kritt_password@db:5432/open_kritt?schema=public

# Backend
NODE_ENV=development
BACKEND_BIND_ADDRESS=127.0.0.1
BACKEND_PORT=3002
# Same-origin frontend requests are proxied internally and need no CORS entry.
# To call the backend from another browser origin, list exact origins separated
# by commas (for example: http://127.0.0.1:4173,https://qa.example.com).
BACKEND_CORS_ORIGINS=
# Host directory holding local repositories to scan. It is bind-mounted into the
# backend and engine containers at /local_repos, so dropping a repo folder here on
# the host makes it appear inside the containers live. (Inside the containers the
# LOCAL_REPOS_PATH env var is overridden to /local_repos by docker-compose.)
LOCAL_REPOS_PATH=./local_repos

# Frontend
FRONTEND_BIND_ADDRESS=127.0.0.1
FRONTEND_PORT=5173
# Keep this empty to use the frontend's same-origin /api proxy. Set an absolute
# URL only when the browser should call a separately hosted backend directly.
VITE_API_BASE_URL=

# Executor view
EXECUTOR_VIEW_BIND_ADDRESS=127.0.0.1
EXECUTOR_VIEW_PORT=8090

# Engine
ENGINE_DATA_DIR=/data
ENGINE_DATA_DIR_HOST=./.data/engine
# Do not start a new per-job scan container below this amount of free storage.
ENGINE_MIN_FREE_STORAGE_GB=20
ENGINE_CHECKOUT_CACHE_DIR=/checkout-cache
ENGINE_CHECKOUT_CACHE_PERSIST_DIR=/data/checkout-cache-persist
# Keep resumable failed/paused/stopped scan caches for this many days.
ENGINE_SCAN_CACHE_RETENTION_DAYS=7
# Absolute Docker-host path corresponding to ENGINE_DATA_DIR. Compose derives
# the default from ${PWD}; set this explicitly if ENGINE_DATA_DIR_HOST changes.
ENGINE_DOCKER_DATA_DIR_HOST=
ENGINE_SCAN_RUNNER_IMAGE=open-kritt-engine:local
# Accounts and the CLI mirror the OpenRouter key here for live services while
# keeping .env synchronized for future Compose runs. Both files use mode 0600.
ENGINE_CREDENTIALS_HOST=./.data/engine/credentials
# Runtime engine knobs are seeded here from env at engine startup, then can be
# edited live to change future job pickup without recreating the container.
ENGINE_RUNTIME_CONFIG_PATH=/data/engine-runtime.env
# Legacy primary Codex login home mounted at /root/.codex. Setup migrates a
# usable login from here into the shared managed accounts root below. Keep it
# project-local because SELinux-enabled Docker hosts may relabel it, and let
# ./kritt manage it as your regular host user; do not run the CLI with sudo.
ENGINE_CODEX_HOME_HOST=./.data/codex
# Codex logins created by Accounts and the CLI live below this shared root.
ENGINE_CODEX_ACCOUNTS_HOST=./.data/codex-accounts
# Legacy non-secret compatibility marker. Current account detection reads the
# active runtime registry and credential files instead of trusting this value.
CODEX_LOGIN_CONFIGURED=
# Optional Codex home source mounted read-only into the engine and executor view.
ENGINE_CODEX_HOME_SOURCE_HOST=./.data/codex-home-source
# Container account list. Accounts and the CLI keep this synchronized with the
# live runtime registry so added and removed logins survive future Compose runs.
ENGINE_CODEX_HOME=/root/.codex
ENGINE_CLAUDE_HOME=./.data/claude
ENGINE_POLL_SECONDS=5
# Aggregate engine worker slots shared by scan steps and post-processing. Two is
# a conservative default for a small 2-vCPU QA/developer machine; increase it
# only with matching CPU, memory, provider limits, and Docker capacity. Set 0 to
# pause pickup of new jobs. These values can also be managed in Settings.
ENGINE_WORKER_COUNT=2
# Maximum immediate scans admitted at once. Queued scans wait until the active
# pool is empty. Set the per-scan worker cap to 0 for automatic, even sharing of
# the aggregate worker slots.
ENGINE_MAX_CONCURRENT_SCANS=1
ENGINE_MAX_WORKERS_PER_SCAN=0
# Lower only an affected scan's future worker cap by one after each provider
# capacity throttle. Account quota limits do not trigger this behavior.
ENGINE_AUTOSCALE_SCAN_WORKERS_ON_PROVIDER_CAPACITY=true
ENGINE_WORKSPACE_SETUP_CONCURRENCY=2
ENGINE_RETRY_COUNT=2
ENGINE_HARNESS_TIMEOUT_SECONDS=7200
# Refresh the account-specific Codex and Anthropic model pickers in the background.
ENGINE_MODEL_CATALOG_REFRESH_SECONDS=300
ENGINE_MODEL_CATALOG_TIMEOUT_SECONDS=10
# The image contains a pinned Codex CLI for reproducible installs. Opt in to
# fetching the newest CLI before startup and daily while idle; this requires
# registry.npmjs.org egress and intentionally gives up version reproducibility.
ENGINE_CODEX_AUTO_UPDATE=false
ENGINE_CODEX_UPDATE_INTERVAL_SECONDS=86400
ENGINE_CODEX_UPDATE_TIMEOUT_SECONDS=120
# Configure model access primarily from Accounts or with `./kritt setup`.
# Accounts writes OpenRouter changes back here for future runs. A GitHub token
# alone cannot run scans.
CODEX_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
CODEX_MODEL_PROVIDER=
# Optional: required only when scanning private GitHub repositories.
GITHUB_TOKEN=
